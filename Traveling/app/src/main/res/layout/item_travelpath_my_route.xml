<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="130dp"
    android:layout_marginBottom="10dp"
    android:background="@drawable/travelpath_my_route_background"
    android:padding="8dp">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/travelpath_my_route_split_guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.4" />

    <ImageView
        android:id="@+id/travelpath_my_route_image"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/travelpath_intro_image_placeholder"
        android:contentDescription="@string/travelpath_my_route_image"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/travelpath_my_route_split_guideline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/travelpath_my_route_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="10dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/travelpath_my_route_split_guideline"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/travelpath_my_route_name"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="bottom"
            android:text="@string/travelpath_my_route_name_placeholder"
            android:textColor="#111827"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/travelpath_my_route_budget"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/travelpath_my_route_budget_placeholder"
                android:textColor="#374151"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/travelpath_my_route_days"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="@string/travelpath_my_route_days_placeholder"
                android:textColor="#374151"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/travelpath_my_route_effort"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="@string/travelpath_my_route_effort_placeholder"
                android:textColor="#374151"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/travelpath_my_route_places"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="top"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="@string/travelpath_my_route_places_placeholder"
            android:textColor="#4B5563"
            android:textSize="13sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

