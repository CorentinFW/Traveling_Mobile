<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <Button
        android:id="@+id/travelpath_continue_button"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:backgroundTint="#000000"
        android:text="@string/travelpath_continue"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/travelpath_progress_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@id/travelpath_continue_button"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ProgressBar
            android:id="@+id/travelpath_progress_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:max="100"
            android:progress="0" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/travelpath_categories_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginBottom="16dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@id/travelpath_progress_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="horizontal">

            <CheckBox
                android:id="@+id/travelpath_category_restaurant"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/travelpath_category_background_selector"
                android:button="@null"
                android:drawablePadding="8dp"
                android:drawableTint="@color/travelpath_category_icon_tint_selector"
                android:drawableTop="@drawable/travelpath_ic_restaurant"
                android:gravity="center"
                android:padding="12dp"
                android:text="@string/travelpath_category_restaurant"
                android:textColor="@color/travelpath_category_text_color_selector"
                android:textStyle="bold" />

            <CheckBox
                android:id="@+id/travelpath_category_culture"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/travelpath_category_background_selector"
                android:button="@null"
                android:drawablePadding="8dp"
                android:drawableTint="@color/travelpath_category_icon_tint_selector"
                android:drawableTop="@drawable/travelpath_ic_culture"
                android:gravity="center"
                android:padding="12dp"
                android:text="@string/travelpath_category_culture"
                android:textColor="@color/travelpath_category_text_color_selector"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="horizontal">

            <CheckBox
                android:id="@+id/travelpath_category_monument"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/travelpath_category_background_selector"
                android:button="@null"
                android:drawablePadding="8dp"
                android:drawableTint="@color/travelpath_category_icon_tint_selector"
                android:drawableTop="@drawable/travelpath_ic_monument"
                android:gravity="center"
                android:padding="12dp"
                android:text="@string/travelpath_category_monument"
                android:textColor="@color/travelpath_category_text_color_selector"
                android:textStyle="bold" />

            <CheckBox
                android:id="@+id/travelpath_category_leisure"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/travelpath_category_background_selector"
                android:button="@null"
                android:drawablePadding="8dp"
                android:drawableTint="@color/travelpath_category_icon_tint_selector"
                android:drawableTop="@drawable/travelpath_ic_leisure"
                android:gravity="center"
                android:padding="12dp"
                android:text="@string/travelpath_category_leisure"
                android:textColor="@color/travelpath_category_text_color_selector"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="horizontal">

            <CheckBox
                android:id="@+id/travelpath_category_shopping"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/travelpath_category_background_selector"
                android:button="@null"
                android:drawablePadding="8dp"
                android:drawableTint="@color/travelpath_category_icon_tint_selector"
                android:drawableTop="@drawable/travelpath_ic_shopping"
                android:gravity="center"
                android:padding="12dp"
                android:text="@string/travelpath_category_shopping"
                android:textColor="@color/travelpath_category_text_color_selector"
                android:textStyle="bold" />

            <CheckBox
                android:id="@+id/travelpath_category_events"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/travelpath_category_background_selector"
                android:button="@null"
                android:drawablePadding="8dp"
                android:drawableTint="@color/travelpath_category_icon_tint_selector"
                android:drawableTop="@drawable/travelpath_ic_events"
                android:gravity="center"
                android:padding="12dp"
                android:text="@string/travelpath_category_events"
                android:textColor="@color/travelpath_category_text_color_selector"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

