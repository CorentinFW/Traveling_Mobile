<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/travelshare_group_detail_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/travelshare_group_detail_title"
            android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/travelshare_group_detail_helper_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/travelshare_group_detail_need_login"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/travelshare_group_detail_members_title"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />

        <LinearLayout
            android:id="@+id/travelshare_group_detail_members_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="6dp" />

        <EditText
            android:id="@+id/travelshare_group_detail_add_member_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:autofillHints="name"
            android:hint="@string/travelshare_group_detail_member_hint"
            android:inputType="textPersonName" />

        <Button
            android:id="@+id/travelshare_group_detail_add_member_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/travelshare_group_detail_add_member_button" />

        <Button
            android:id="@+id/travelshare_group_detail_leave_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/travelshare_group_detail_leave_button" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/travelshare_group_detail_messages_title"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />

        <LinearLayout
            android:id="@+id/travelshare_group_detail_messages_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="6dp" />

        <EditText
            android:id="@+id/travelshare_group_detail_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:autofillHints="message"
            android:hint="@string/travelshare_group_detail_message_hint"
            android:inputType="textMultiLine" />

        <Button
            android:id="@+id/travelshare_group_detail_send"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/travelshare_group_detail_send_button" />
    </LinearLayout>
</ScrollView>


