<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/travelshare_add_title"
            android:textAppearance="@style/TextAppearance.Material3.TitleLarge" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/travelshare_add_subtitle"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium" />

        <EditText
            android:id="@+id/travelshare_add_location_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:hint="@string/travelshare_add_location_hint"
            android:inputType="textCapWords" />

        <EditText
            android:id="@+id/travelshare_add_period_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/travelshare_add_period_hint"
            android:inputType="textCapWords" />

        <EditText
            android:id="@+id/travelshare_add_description_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/travelshare_add_description_hint"
            android:inputType="textMultiLine" />

        <EditText
            android:id="@+id/travelshare_add_how_to_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/travelshare_add_how_to_hint"
            android:inputType="textMultiLine" />

        <Button
            android:id="@+id/travelshare_add_publish_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/travelshare_add_publish" />

    </LinearLayout>
</ScrollView>
