<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">
    <!-- Top Bar with Title and Add Button -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/travelshare_messages_title"
            android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
            android:layout_centerVertical="true" />
        <ImageButton
            android:id="@+id/travelshare_messages_add_btn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_input_add"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Add group or message" />
    </RelativeLayout>
    <TextView
        android:id="@+id/travelshare_messages_helper_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/travelshare_messages_connected_hint"
        android:textAppearance="@style/TextAppearance.Material3.BodyMedium" />
    <!-- Group Creation Layout (Hidden by default) -->
    <LinearLayout
        android:id="@+id/travelshare_messages_add_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="14dp"
        android:visibility="gone">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/travelshare_groups_create_title"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />
        <EditText
            android:id="@+id/travelshare_messages_group_name_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/travelshare_groups_name_hint"
            android:inputType="textPersonName" />
        <EditText
            android:id="@+id/travelshare_messages_group_members_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:hint="@string/travelshare_groups_members_hint"
            android:inputType="text" />
        <Button
            android:id="@+id/travelshare_messages_group_create_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/travelshare_groups_create_button" />
    </LinearLayout>
    <!-- Combined List for Conversations and Groups -->
    <ListView
        android:id="@+id/travelshare_messages_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:layout_weight="1" />
</LinearLayout>
