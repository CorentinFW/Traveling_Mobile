<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <Button
        android:id="@+id/travelpath_continue_button"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:backgroundTint="#000000"
        android:text="@string/travelpath_continue"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ProgressBar
        android:id="@+id/travelpath_progress_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="8dp"
        android:layout_marginBottom="16dp"
        android:max="100"
        android:progress="20"
        app:layout_constraintBottom_toTopOf="@id/travelpath_continue_button"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <FrameLayout
        android:id="@+id/travelpath_map_container"
        android:layout_width="0dp"
        android:layout_height="180dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/travelpath_intro_image_placeholder"
        android:contentDescription="@string/travelpath_map"
        app:layout_constraintBottom_toTopOf="@id/travelpath_progress_bar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginBottom="16dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/travelpath_map_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/travelpath_filters_row">

        <LinearLayout
            android:id="@+id/travelpath_results_injection_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <include layout="@layout/item_travelpath_result" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/travelpath_filters_row"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/travelpath_search_view">

        <Spinner
            android:id="@+id/travelpath_filter_spinner"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:background="@drawable/travelpath_accordion_background"
            android:entries="@array/travelpath_filter_placeholders"
            android:minWidth="120dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:spinnerMode="dropdown" />

        <Spinner
            android:id="@+id/travelpath_sort_spinner"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/travelpath_accordion_background"
            android:entries="@array/travelpath_sort_placeholders"
            android:minWidth="100dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:spinnerMode="dropdown" />

        <TextView
            android:id="@+id/travelpath_results_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:gravity="end"
            android:text="@string/travelpath_results_count_placeholder"
            android:textColor="#111827"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.appcompat.widget.SearchView
        android:id="@+id/travelpath_search_view"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:background="@drawable/travelpath_accordion_background"
        android:iconifiedByDefault="false"
        android:queryHint="@string/travelpath_search_hint"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

