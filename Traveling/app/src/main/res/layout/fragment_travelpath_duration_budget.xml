<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <Button
        android:id="@+id/travelpath_continue_button"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:backgroundTint="#000000"
        android:text="@string/travelpath_continue"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ProgressBar
        android:id="@+id/travelpath_progress_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="8dp"
        android:layout_marginBottom="16dp"
        android:max="100"
        android:progress="40"
        app:layout_constraintBottom_toTopOf="@id/travelpath_continue_button"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/travelpath_progress_bar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <Space
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/travelpath_visit_duration_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/travelpath_visit_duration_title"
                android:textColor="#111827"
                android:textSize="22sp"
                android:textStyle="bold" />

            <Space
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <RadioGroup
                android:id="@+id/travelpath_duration_group"
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/travelpath_duration_half_day"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/travelpath_choice_background_selector"
                    android:button="@null"
                    android:checked="true"
                    android:gravity="center"
                    android:text="@string/travelpath_duration_half_day"
                    android:textColor="@color/travelpath_choice_text_color_selector"
                    android:textStyle="bold" />

                <RadioButton
                    android:id="@+id/travelpath_duration_full_day"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/travelpath_choice_background_selector"
                    android:button="@null"
                    android:gravity="center"
                    android:text="@string/travelpath_duration_full_day"
                    android:textColor="@color/travelpath_choice_text_color_selector"
                    android:textStyle="bold" />

                <RadioButton
                    android:id="@+id/travelpath_duration_multiple_days"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/travelpath_choice_background_selector"
                    android:button="@null"
                    android:gravity="center"
                    android:text="@string/travelpath_duration_multiple_days"
                    android:textColor="@color/travelpath_choice_text_color_selector"
                    android:textStyle="bold" />
            </RadioGroup>

            <Space
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <EditText
                android:id="@+id/travelpath_multiple_days_input"
                android:layout_width="200dp"
                android:layout_height="48dp"
                android:background="@drawable/travelpath_accordion_background"
                android:enabled="false"
                android:gravity="center"
                android:hint="@string/travelpath_days_input_hint"
                android:inputType="number"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="#111827"
                android:textColorHint="#6B7280" />

            <Space
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/travelpath_visit_start_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/travelpath_visit_start_title"
                android:textColor="#111827"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Space
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <Spinner
                android:id="@+id/travelpath_visit_start_spinner"
                android:layout_width="200dp"
                android:layout_height="48dp"
                android:background="@drawable/travelpath_accordion_background"
                android:entries="@array/travelpath_visit_start_options"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:spinnerMode="dropdown" />

            <Space
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <SeekBar
                android:id="@+id/travelpath_budget_slider"
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:max="2000"
                android:progress="0" />

            <Space
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <LinearLayout
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="start|center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/travelpath_budget_min_label"
                        android:textColor="#111827"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/travelpath_budget_min_input"
                        android:layout_width="52dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:background="@android:color/transparent"
                        android:gravity="center"
                        android:inputType="number"
                        android:text="0"
                        android:textColor="#111827" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/travelpath_budget_currency"
                        android:textColor="#111827"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end|center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/travelpath_budget_max_label"
                        android:textColor="#111827"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/travelpath_budget_max_input"
                        android:layout_width="52dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:background="@android:color/transparent"
                        android:gravity="center"
                        android:inputType="number"
                        android:text="2000"
                        android:textColor="#111827" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/travelpath_budget_currency"
                        android:textColor="#111827"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <Space
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1" />
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>


